{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:ios": "eas build --clear-cache --platform ios",
    "build:android": "eas build --clear-cache --platform android",
    "build:dev:ios": "pnpm build:ios --profile development",
    "build:android:apk": "pnpm build:android --profile production-apk",
    "build:dev:android": "pnpm build:android --profile development",
    "local:build:ios": "pnpm build:ios --local",
    "local:build:android": "pnpm build:android --local",
    "local:build:dev:ios": "pnpm build:ios --profile development --local",
    "local:build:android:apk": "pnpm build:android --profile production-apk --local",
    "local:build:dev:android": "pnpm build:android --profile development  --local"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.0.1",
    "@react-native-async-storage/expo-with-async-storage": "1.0.0",
    "@react-navigation/bottom-tabs": "^7.7.3",
    "@react-navigation/elements": "^2.8.1",
    "@react-navigation/native": "^7.1.28",
    "clsx": "2.1.1",
    "expo": "~55.0.4",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.10",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-image": "~55.0.5",
    "expo-linking": "~55.0.7",
