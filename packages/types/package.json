{
  "private": true,
  "version": "0.2.0",
  "description": "types",
  "name": "@xiaoqianshuo/types",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "build:prod": "tsup --minify",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json}'"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "keywords": [
    "xiaoqianshuo",
    "types"
  ],
  "author": "xiaoqianshuo",
  "license": "MIT",
  "dependencies": {
    "@xiaoqianshuo/prettier-config": "workspace:^",
    "zod": "4.3.5"
  }
}
