{
  "name": "@xiaoqianshuo/utils",
  "version": "1.2.5",
  "type": "module",
  "license": "MIT",
  "author": "xiaoqianshuo",
  "description": "utils for xiaoqianshuo",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "browser": "./dist/umd/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./types/*.d.ts",
        "default": "./dist/esm/*.js"
      },
      "require": {
        "types": "./types/*.d.ts",
        "default": "./dist/cjs/*.cjs"
      }
    }
  },
  "scripts": {
    "build:rollup": "rimraf dist && rollup -c",
    "build:types": "rimraf types && tsc -p tsconfig.types.json",
    "build": "pnpm build:rollup && pnpm build:types",
    "build:prod": "NODE_ENV=production pnpm build:rollup && pnpm build:types",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json}'",
    "test": "rimraf coverage && jest --coverage"
  },
  "keywords": [
    "xiaoqianshuo",
    "utils"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoqianshuo/xiaoqianshuo.git"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "types",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "http://qlqs.work:4873",
    "tag": "latest"
  }
}
