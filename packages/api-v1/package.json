{
  "private": true,
  "name": "@xiaoqianshuo/api-v1",
  "version": "0.0.0",
  "description": "api request v1",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "import": "./dist/modules/*.js",
      "require": "./dist/modules/*.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:prod": "tsup --minify",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json}'"
  },
  "dependencies": {
    "@xiaoqianshuo/api-core": "workspace:^",
    "@xiaoqianshuo/types": "workspace:^",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@xiaoqianshuo/prettier-config": "workspace:^"
  },
  "keywords": [
    "xiaoqianshuo",
    "api-v1"
  ],
  "author": "xiaoqianshuo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoqianshuo/xiaoqianshuo.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "http://qlqs.work:4873",
    "tag": "latest"
  }
}
